# Copy to .env.local and fill in. Never commit real values (.env* is gitignored).

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — bypasses RLS. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ── Strava (OAuth + activity sync) ────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Shared token for the webhook subscription verify handshake.
STRAVA_VERIFY_TOKEN=
# Optional: the push-subscription id (from /api/strava/webhook/register?action=view).
# When set, the webhook POST handler ignores events from other subscriptions.
STRAVA_SUBSCRIPTION_ID=

# ── intervals.icu (wellness / fitness-form) ───────────────────
# NOTE: multi-tenant — each user's intervals.icu API key + athlete id now live in
# the `user_integrations` table (entered via Settings → Integrations), NOT here.
# INTERVALS_API_KEY / INTERVALS_WORKOUT_SYNC env vars are no longer read.

# ── Cron (scheduled jobs) ─────────────────────────────────────
# cron-job.org sends this as `Authorization: Bearer <CRON_SECRET>` on scheduled
# invocations of /api/wellness/sync, /api/coach/run and /api/coach/morning (the
# schedule is external — not Vercel Cron). Set the same value in the Vercel project
# settings. Generate: openssl rand -hex 32
CRON_SECRET=

# ── Coach (Claude / Anthropic) ────────────────────────────────
# Used by /api/coach/run and /api/coach/morning to generate the review/briefing.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8).
COACH_MODEL=

# ── Telegram (nightly coach message delivery) ─────────────────
# Bot token from @BotFather (/newbot) — a single shared bot serves every user.
# NOTE: multi-tenant — each user's chat id now lives in the `user_integrations`
# table (entered via Settings → Integrations), NOT here. Chat id: message the bot
# once, then read result[].message.chat.id from
# https://api.telegram.org/bot<token>/getUpdates.
TELEGRAM_BOT_TOKEN=

# ── App ───────────────────────────────────────────────────────
# Base URL for absolute redirects (defaults to https://paceline.run).
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Access allowlist (multi-tenant). Comma-separated emails allowed to sign in and own
# their own data — every other authenticated account resolves to null everywhere auth
# is checked. Set this in production (belt-and-braces alongside disabling Supabase
# signups). Unset → any authed account is treated as an owner (dev fallback).
OWNER_EMAILS=
# Optional comma-separated read-only guest emails (pass the page/read gate, fail every
# write gate). See src/lib/auth.ts.
VIEWER_EMAILS=

# ── Dev login (Chrome-preview auth bypass; ignored in production) ──
# Gate is VERCEL_ENV !== 'production' AND a matching secret.
DEV_LOGIN_SECRET=
DEV_LOGIN_EMAIL=

# ── Plan agent (headless coach) ───────────────────────────────
# Bearer token the evening-coach agent uses to call /api/plan-context and
# /api/plan-change without a browser session. Must match in Vercel (prod) and
# wherever the agent reads it. Generate: openssl rand -hex 32
PLAN_AGENT_TOKEN=
# The user id (auth.users.id) the headless plan agent operates on — the owner whose
# data the token-authenticated coach agent manages. Required for the token path now
# that data is per-user.
PLAN_AGENT_USER_ID=
